generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                 @id @default(uuid())
  email                   String                 @unique
  password                String
  fullName                String?
  stageName               String?
  role                    String                 @default("artist")
  status                  String                 @default("pending")
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  monthlyListeners        Int?
  spotifyUrl              String?
  permissions             String?
  legalName               String?
  phoneNumber             String?
  address                 String?
  emailVerified           DateTime?
  verificationToken       String?
  verificationTokenExpiry DateTime?
  notifyContracts         Boolean                @default(true)
  notifyDemos             Boolean                @default(true)
  notifyEarnings          Boolean                @default(true)
  notifySupport           Boolean                @default(true)
  resetToken              String?
  resetTokenExpiry        DateTime?
  discordId               String?
  discordNotifyEnabled    Boolean                @default(false)
  artist                  Artist?
  assignedRequests        ChangeRequest[]        @relation("AssignedRequests")
  requests                ChangeRequest[]        @relation("UserRequests")
  comments                ChangeRequestComment[]
  contracts               Contract[]
  demos                   Demo[]
  payments                Payment[]
  royaltySplits           RoyaltySplit[]
}

model Demo {
  id                   String     @id @default(uuid())
  title                String
  genre                String?
  trackLink            String?
  message              String?
  status               String     @default("pending")
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  artistId             String
  reviewedAt           DateTime?
  reviewedBy           String?
  rejectionReason      String?
  scheduledReleaseDate String?
  featuredArtists      String?
  contract             Contract?
  artist               User       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  files                DemoFile[]

  @@index([artistId, createdAt(sort: Desc)], map: "idx_demo_artist_id_created_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_demo_status_created_at")
}

model DemoFile {
  id        String   @id @default(uuid())
  filename  String
  filepath  String
  filesize  Int
  createdAt DateTime @default(now())
  demoId    String
  demo      Demo     @relation(fields: [demoId], references: [id], onDelete: Cascade)
}

model SiteContent {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  content   String
  updatedAt DateTime @updatedAt
}

model Webhook {
  id        String   @id @default(uuid())
  name      String
  url       String
  events    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  config    String?
}

model Artist {
  id               String               @id @default(uuid())
  name             String
  image            String?
  spotifyUrl       String?
  email            String?
  status           String               @default("active")
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  userId           String?              @unique
  followers        Int?                 @default(0)
  genres           String?
  lastSyncedAt     DateTime?
  monthlyListeners Int?                 @default(0)
  verified         Boolean?             @default(false)
  popularity       Int?                 @default(0)
  user             User?                @relation(fields: [userId], references: [id])
  statsHistory     ArtistStatsHistory[]
  contracts        Contract[]
  royaltySplits    RoyaltySplit[]
}

model ArtistStatsHistory {
  id               String   @id @default(uuid())
  artistId         String
  monthlyListeners Int
  followers        Int?
  date             DateTime @default(now())
  popularity       Int?
  artist           Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, date])
}

model Release {
  id              String          @id @default(uuid())
  name            String
  artistName      String?
  image           String?
  spotifyUrl      String?
  releaseDate     String?
  artistsJson     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  popularity      Int?
  streamCountText String?
  type            String          @default("album")
  totalTracks     Int             @default(1)
  previewUrl      String?
  baseTitle       String?
  versionName     String?
  requests        ChangeRequest[]
  contracts       Contract[]

  @@index([baseTitle])
}

model ChangeRequest {
  id           String                 @id @default(uuid())
  type         String
  status       String                 @default("pending")
  details      String?
  adminNote    String?
  filesJson    String?
  releaseId    String?
  userId       String
  assignedToId String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  assignedTo   User?                  @relation("AssignedRequests", fields: [assignedToId], references: [id])
  release      Release?               @relation(fields: [releaseId], references: [id])
  user         User                   @relation("UserRequests", fields: [userId], references: [id], onDelete: Cascade)
  comments     ChangeRequestComment[]

  @@index([assignedToId, createdAt(sort: Desc)], map: "idx_change_request_assigned_to_created_at")
  @@index([status, createdAt(sort: Desc)], map: "idx_change_request_status_created_at")
  @@index([userId, createdAt(sort: Desc)], map: "idx_change_request_user_id_created_at")
}

model ChangeRequestComment {
  id        String        @id @default(uuid())
  requestId String
  userId    String
  content   String
  createdAt DateTime      @default(now())
  request   ChangeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])
}

model SystemSettings {
  id        String   @id @default("default")
  config    String
  updatedAt DateTime @updatedAt
}

model Contract {
  id                 String         @id @default(uuid())
  releaseId          String?
  userId             String?
  artistId           String?
  primaryArtistName  String?
  primaryArtistEmail String?
  title              String?
  demoId             String?        @unique
  artistShare        Float          @default(0.70)
  labelShare         Float          @default(0.30)
  status             String         @default("active")
  signedAt           DateTime?
  terminatedAt       DateTime?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  pdfUrl             String?
  featuredArtists    String?
  artist             Artist?        @relation(fields: [artistId], references: [id])
  demo               Demo?          @relation(fields: [demoId], references: [id])
  release            Release?       @relation(fields: [releaseId], references: [id])
  user               User?          @relation(fields: [userId], references: [id])
  earnings           Earning[]
  splits             RoyaltySplit[]

  @@index([artistId, createdAt(sort: Desc)], map: "idx_contract_artist_id_created_at")
  @@index([releaseId], map: "idx_contract_release_id")
  @@index([status, createdAt(sort: Desc)], map: "idx_contract_status_created_at")
  @@index([userId, createdAt(sort: Desc)], map: "idx_contract_user_id_created_at")
}

model RoyaltySplit {
  id         String   @id @default(uuid())
  contractId String
  userId     String?
  name       String
  percentage Float
  artistId   String?
  email      String?
  artist     Artist?  @relation(fields: [artistId], references: [id])
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])
}

model Earning {
  id            String    @id @default(uuid())
  contractId    String
  period        String
  grossAmount   Float
  artistAmount  Float
  labelAmount   Float
  currency      String    @default("USD")
  streams       Int?
  source        String?
  expenseAmount Float     @default(0)
  paidToArtist  Boolean   @default(false)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  contract      Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, period(sort: Desc)], map: "idx_earning_contract_id_period")
  @@index([createdAt(sort: Desc)], map: "idx_earning_created_at")
}

model Payment {
  id          String    @id @default(uuid())
  userId      String
  amount      Float
  currency    String    @default("USD")
  method      String?
  reference   String?
  status      String    @default("pending")
  processedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])

  @@index([status, createdAt(sort: Desc)], map: "idx_payment_status_created_at")
  @@index([userId, createdAt(sort: Desc)], map: "idx_payment_user_id_created_at")
}

model discord_account_links {
  user_id          String   @id
  discord_user_id  String   @unique
  discord_username String?
  discord_avatar   String?
  guild_id         String?
  linked_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  @@index([discord_user_id], map: "idx_discord_account_links_discord_user_id")
}

model discord_event_outbox {
  id              BigInt   @id @default(autoincrement())
  event_type      String
  aggregate_id    String?
  payload         Json
  status          String   @default("pending")
  attempts        Int      @default(0)
  next_attempt_at DateTime @default(now()) @db.Timestamptz(6)
  last_error      String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([status, next_attempt_at, created_at], map: "idx_discord_event_outbox_pending")
}

model discord_internal_audit {
  id              BigInt   @id @default(autoincrement())
  request_id      String?
  endpoint        String
  method          String
  discord_user_id String?
  guild_id        String?
  success         Boolean  @default(false)
  status_code     Int?
  signature       String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_discord_internal_audit_created_at")
  @@index([request_id], map: "idx_discord_internal_audit_request_id")
  @@index([signature], map: "idx_discord_internal_audit_signature")
}

model discord_oauth_states {
  state            String    @id
  user_id          String?
  discord_user_id  String?
  discord_username String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  expires_at       DateTime  @db.Timestamptz(6)
  consumed_at      DateTime? @db.Timestamptz(6)

  @@index([expires_at], map: "idx_discord_oauth_states_expires_at")
}

model discord_role_sync_queue {
  id                     BigInt   @id @default(autoincrement())
  user_id                String
  discord_user_id        String?
  target_role            String
  target_discord_role_id String?
  status                 String   @default("pending")
  attempts               Int      @default(0)
  last_error             String?
  guild_id               String?
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @default(now()) @db.Timestamptz(6)

  @@index([status, created_at], map: "idx_discord_role_sync_queue_pending")
}
